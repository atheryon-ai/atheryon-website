{
  "routes": [
    { "route": "/reality",                "redirect": "/",            "statusCode": 301 },
    { "route": "/data",                   "redirect": "/system",      "statusCode": 301 },
    { "route": "/ai-direction",           "redirect": "/workflows",   "statusCode": 301 },
    { "route": "/transformation",         "redirect": "/engagements", "statusCode": 301 },

    { "route": "/cdm-platform",           "redirect": "/system",      "statusCode": 301 },
    { "route": "/recovery-migration",     "redirect": "/engagements", "statusCode": 301 },
    { "route": "/m-and-a-execution",      "redirect": "/engagements", "statusCode": 301 },
    { "route": "/capability-enablement",  "redirect": "/engagements", "statusCode": 301 },
    { "route": "/how-we-work",            "redirect": "/approach",    "statusCode": 301 },
    { "route": "/approach",               "redirect": "/system",      "statusCode": 301 },
    { "route": "/what-we-deliver",        "redirect": "/engagements", "statusCode": 301 },
    { "route": "/ai-ready-data",          "redirect": "/system",      "statusCode": 301 },
    { "route": "/intelligence",           "redirect": "/workflows",   "statusCode": 301 },
    { "route": "/reference-architectures","redirect": "/system",      "statusCode": 301 },

    { "route": "/labs/code",                   "redirect": "/offers/code",    "statusCode": 301 },
    { "route": "/labs/prompts",                "redirect": "/offers/prompts", "statusCode": 301 },
    { "route": "/labs/advisory",               "redirect": "/offers/consult", "statusCode": 301 },
    { "route": "/programs/mib-insight",        "redirect": "/offers/prompts", "statusCode": 301 },
    { "route": "/programs/mib-insight/thanks", "redirect": "/offers/prompts/thanks", "statusCode": 301 },
    { "route": "/engagements",                 "redirect": "/offers",         "statusCode": 301 },

    { "route": "/system",      "rewrite": "/system.html" },
    { "route": "/workflows",   "rewrite": "/workflows.html" },
    { "route": "/about",       "rewrite": "/about.html" },
    { "route": "/contact",     "rewrite": "/contact.html" },

    { "route": "/offers",         "rewrite": "/offers.html" },
    { "route": "/offers/code",    "rewrite": "/offers/code.html" },
    { "route": "/offers/prompts",        "rewrite": "/offers/prompts.html" },
    { "route": "/offers/prompts/thanks", "rewrite": "/offers/prompts/thanks.html" },
    { "route": "/offers/consult", "rewrite": "/offers/consult.html" },

    { "route": "/labs",        "rewrite": "/labs.html" },
    { "route": "/programs",    "rewrite": "/programs.html" },
    { "route": "/integration/*",                 "allowedRoles": ["sp-clients"] },
    { "route": "/privacy",                       "rewrite": "/privacy.html" },
    { "route": "/terms",                         "rewrite": "/terms.html" }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/integration/atheryon-sp-integration.pdf",
      "statusCode": 302
    },
    "404": {
      "rewrite": "/404.html",
      "statusCode": 404
    }
  },
  "globalHeaders": {
    "Cache-Control": "public, max-age=3600",
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY"
  },
  "mimeTypes": {
    ".json": "application/json",
    ".woff2": "font/woff2",
    ".woff": "font/woff"
  }
}
